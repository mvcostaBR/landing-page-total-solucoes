        {
          "@type": "Question",
          "name": "Quais aparelhos são atendidos?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "São atendidos modelos Split residenciais instalados em apartamentos e casas dentro da área de atendimento desta página."
          }
        },
        {
          "@type": "Question",
          "name": "Quais são os valores da higienização?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Split de 9.000 até 18.000 BTUs: R$350,00. Split de 22.000 até 30.000 BTUs: R$450,00. Condensadora, avaliada no local: R$150,00."
          }
        },
        {
          "@type": "Question",
          "name": "Como funciona o valor da condensadora?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A condensadora é avaliada no local, com valor de R$150,00."
          }
        },
        {
          "@type": "Question",
          "name": "Quais regiões são atendidas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Na Zona Oeste: Barra, Recreio e Freguesia. Na Zona Sul: Leblon, São Conrado, Joá, Jardim Botânico, Lagoa e Botafogo."
          }
        },
        {
          "@type": "Question",
          "name": "Qual é o horário de atendimento?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "De segunda a sexta, das 08h às 18h."
          }
        },
        {
          "@type": "Question",
          "name": "Como faço para agendar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "O agendamento é realizado exclusivamente pelo WhatsApp, por meio dos botões disponíveis nesta página."
          }
        },
        {
          "@type": "Question",
          "name": "É necessário preencher formulário?",
