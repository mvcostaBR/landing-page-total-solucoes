      "mainEntity": [
        {
          "@type": "Question",
          "name": "Quais aparelhos a Total Soluções Prediais atende?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Realizamos a higienização de ar condicionado residencial exclusivamente para modelos Split de 9.000 a 30.000 BTUs. Não atendemos aparelhos de janela."
          }
        },
        {
          "@type": "Question",
          "name": "Quanto custa a higienização do ar condicionado Split?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Os valores da unidade evaporadora são R$350,00 para Split de 9.000 a 18.000 BTUs e R$450,00 para Split de 22.000 a 30.000 BTUs. Caso a condensadora também precise de higienização, após avaliação no local, são acrescentados R$150,00 por unidade."
          }
        },
        {
          "@type": "Question",
          "name": "Em quais bairros a Total Soluções Prediais atende?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Atendemos na Barra, Recreio, Freguesia, Leblon, São Conrado, Joá, Jardim Botânico, Lagoa e Botafogo, no Rio de Janeiro."
          }
        },
        {
          "@type": "Question",
          "name": "Qual é o horário de atendimento?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Atendemos de segunda a sexta-feira, das 8h às 18h. Atendimento e agendamento exclusivos pelo WhatsApp."
          }
        },
        {
          "@type": "Question",
          "name": "Quais serviços não estão incluídos?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Não estão incluídos manutenção corretiva, instalação, troca de peças, PMOC, projetos ou atendimento a equipamentos comerciais, industriais e aparelhos de janela."
          }
        }
      ]
